# ============================================================================
# 防止源码内构建
# ============================================================================

if(CMAKE_SOURCE_DIR STREQUAL CMAKE_BINARY_DIR)
    message(FATAL_ERROR
        "禁止在源码目录内构建！\n"
        "请使用外部构建目录：\n"
        "  mkdir build && cd build && cmake ..\n"
        "或使用构建脚本：\n"
        "  ./build.sh\n"
    )
endif()
