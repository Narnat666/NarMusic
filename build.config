# ============================================================================
# HTTP Server ARM64 Linux 构建配置文件
# 专门为ARM64 Linux平台设计
# ============================================================================

# 项目信息
PROJECT_NAME="NarMusic"
PROJECT_VERSION="1.0.0"
PROJECT_DESCRIPTION="C++ Music Server for ARM64 Linux"

# 默认构建配置
DEFAULT_BUILD_TYPE="Release"
DEFAULT_ARCH="aarch64"           # 专注于ARM64
DEFAULT_PLATFORM="linux"         # 专注于Linux

# 交叉编译工具链配置
# 默认使用系统PATH中的交叉编译器
TOOLCHAIN_PREFIX="aarch64-linux-gnu"

# 输出目录配置
BUILD_DIR_PREFIX="build"
INSTALL_PREFIX="/usr/local"
PACKAGE_DIR="dist"

# ============================================================================
# 自定义编译器路径
# ============================================================================

# 如果您有自定义的交叉编译工具链，可以在这里设置
# 或者使用命令行参数：--cc /path/to/compiler --cxx /path/to/c++-compiler
# 或者使用环境变量：CC=/path/to/compiler CXX=/path/to/c++-compiler

# 示例：
# CC="/opt/linaro-12.3/bin/aarch64-linux-gnu-gcc"
# CXX="/opt/linaro-12.3/bin/aarch64-linux-gnu-g++"
# SYSROOT_DIR="/opt/linaro-12.3/aarch64-linux-gnu/sysroot"

# ============================================================================
# 构建选项
# ============================================================================

# 并行编译任务数，默认为CPU核心数
# JOBS=4

# 详细输出
# VERBOSE=false

# ============================================================================
# 平台检测
# ============================================================================

# 自动检测主机平台
HOST_OS=$(uname -s)
HOST_ARCH=$(uname -m)

# 显示平台信息
echo "主机平台: ${HOST_OS} ${HOST_ARCH}"
echo "目标平台: ${DEFAULT_ARCH} ${DEFAULT_PLATFORM}"

# ============================================================================
# 依赖库路径
# ============================================================================

# 项目包含预编译的ARM64依赖库
# 库文件位于: lib/
# 头文件位于: include/

# 如果需要使用系统库，可以在这里设置路径
# CMAKE_PREFIX_PATH="/usr/local:/opt/homebrew"

# ============================================================================
# 使用说明
# ============================================================================

# 基本用法:
#   ./build.sh                    # 默认ARM64交叉编译
#   ./build.sh -a native          # 本地构建
#   ./build.sh -t Debug           # Debug构建
#   ./build.sh -c                 # 清理
#   ./build.sh -p                 # 创建发布包

# 自定义编译器:
#   ./build.sh --cc /path/to/gcc --cxx /path/to/g++
#   或
#   export CC=/path/to/gcc
#   export CXX=/path/to/g++
#   ./build.sh

# 查看帮助:
#   ./build.sh --help